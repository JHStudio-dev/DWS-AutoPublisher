# DWS PublishFlow — environment configuration template
# Copy this file to .env.local and fill in real values.
# Never commit .env or .env*.local. Only this template is committed.

# --- Supabase (public, safe to expose to the browser) ---
# RLS-gated. These are read by both client and server.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only, NEVER expose to the browser) ---
# Used only by the server-side admin client for narrow privileged operations.
# Do not prefix with NEXT_PUBLIC_. Do not log. Do not commit.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Base URL of the app (used for auth redirects, e.g. password reset).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Future integrations (reserved; leave blank until those phases) ---
# Meta Pages / Instagram Business API (server-only, stored encrypted at rest).
# META_APP_ID=
# META_APP_SECRET=
# Outbound automation webhooks (n8n / Make).
# WEBHOOK_SIGNING_SECRET=
